---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.tsx';
import ParallaxGallery from '../components/ParallaxGallery.tsx';
import SiteCard from '../components/SiteCard.tsx';
import Services from '../components/Services.tsx';
import ThemeSwitcher from '../components/ThemeSwitcher.tsx';
import SmoothScroll from '../components/SmoothScroll.tsx';
import AnimatedHeadline from '../components/AnimatedHeadline.tsx';
import { hero, about, services, disclaimer } from '../data/site';
import { gallery } from '../data/gallery';
import { charity } from '../data/charity';
---
<Layout title="prem-ium.online — Websites for local businesses" description={hero.sub}>
  <nav class="sticky top-0 z-40 flex items-center justify-between border-b border-white/10 bg-[#050608]/80 px-6 py-4 text-white backdrop-blur">
    <a href="#top" class="display text-lg font-semibold">prem-ium<span class="text-accent">.online</span></a>
    <ul class="hidden gap-6 text-sm text-white/80 md:flex">
      <li><a href="#about" class="hover:text-accent">About</a></li>
      <li><a href="#work" class="hover:text-accent">Work</a></li>
      <li><a href="/portfolio" class="hover:text-accent">All sites</a></li>
      <li><a href="#charity" class="hover:text-accent">Charity</a></li>
      <li><a href="#services" class="hover:text-accent">Services</a></li>
      <li><a href="#contact" class="hover:text-accent">Contact</a></li>
    </ul>
    <div class="flex items-center gap-3">
      <a href="https://portal.prem-ium.online" class="hidden text-sm text-white/80 hover:text-accent sm:inline">Portal ↗</a>
      <a href="#contact" class="rounded-btn bg-accent px-4 py-2 text-sm font-medium text-white shadow-soft">Let's talk</a>
    </div>
  </nav>

  <section id="top" class="relative overflow-hidden" style="background:rgb(5 6 8 / 0.55)">
    <div class="mx-auto grid min-h-[90vh] max-w-7xl items-center gap-6 px-6 py-16 md:grid-cols-2 md:gap-8">
      <div class="relative z-10 text-left">
        <p class="eyebrow mb-4">{hero.eyebrow}</p>
        <AnimatedHeadline
          client:load
          as="h1"
          text={hero.headline}
          emphasize={hero.emphasize}
          outline={['small']}
          className="text-5xl leading-[1.04] text-white md:text-6xl lg:text-7xl"
        />
        <p class="mt-6 max-w-md text-lg text-white/60">{hero.sub}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={hero.ctaHref} class="rounded-btn bg-accent px-6 py-3 font-medium text-white shadow-soft transition-transform hover:-translate-y-0.5">{hero.ctaLabel}</a>
          <a href={hero.ctaHref2} class="rounded-btn border border-white/20 px-6 py-3 font-medium text-white transition-colors hover:bg-white/5">{hero.ctaLabel2}</a>
        </div>
      </div>
      {/* right column intentionally empty — the fixed flying blob occupies it at the top of the page */}
    </div>
    <div class="pointer-events-none absolute bottom-6 left-1/2 -translate-x-1/2 text-xs uppercase tracking-[3px] text-white/40">Scroll ↓</div>
  </section>

  <About
    client:load
    eyebrow={about.eyebrow}
    headline={about.headline}
    emphasize={about.emphasize}
    paragraphs={about.paragraphs}
  />

  <section id="work" class="relative overflow-hidden px-6 py-20" style="background:rgb(5 6 8 / 0.72)">
    <div class="mx-auto max-w-6xl">
      <ParallaxGallery client:visible shots={gallery} />
      <div class="mt-12 text-center">
        <a href="/portfolio" class="inline-flex items-center justify-center rounded-btn border border-white/20 px-6 py-3 font-medium text-white transition-colors hover:bg-white/5">
          See every site we've built →
        </a>
      </div>
    </div>
  </section>

  <section id="charity" class="relative overflow-hidden px-6 py-24" style="background:rgb(5 6 8 / 0.72)">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow mb-4">Built free · Given away</p>
      <AnimatedHeadline client:visible as="h2" text="Good websites shouldn't cost anything." emphasize={['cost', 'anything']} className="mb-4 text-3xl leading-tight text-white md:text-4xl" />
      <p class="mb-10 max-w-xl text-white/60">
        prem-ium.online isn't just a portfolio — it's charity. Every website here was designed, built, and deployed at
        no cost, then given to a local business that could never afford one. No fees, no catch. If one of these is
        yours, <a href="#contact" class="text-accent underline">it's yours to keep</a>.
      </p>
      <div class="grid gap-6 md:grid-cols-3">
        {charity.map((s, i) => (
          <SiteCard client:visible business={s.business} city={s.city} category={s.category} renderUrl={s.renderUrl} whyFree={s.whyFree} i={i} variant="charity" />
        ))}
      </div>
    </div>
  </section>

  <section id="services" class="relative px-6 py-24" style="background:rgb(var(--bg-rgb) / 0.85)">
    <div class="mx-auto max-w-6xl">
      <AnimatedHeadline client:visible as="h2" text="What I do." outline={['do']} className="mb-10 text-3xl text-ink md:text-4xl" />
      <Services client:visible items={services} />
    </div>
  </section>

  <section id="contact" class="relative px-6 py-24 text-center" style="background:rgb(var(--bg-rgb) / 0.85)">
    <div class="mx-auto max-w-2xl">
      <AnimatedHeadline client:visible as="h2" text="Let's build something." emphasize={['something.']} outline={['build']} className="mb-4 text-3xl text-ink md:text-4xl" />
      <p class="mb-8 text-ink">Have a business that needs a real website — or think one of the free ones above is yours? Reach out.</p>
      <a href="mailto:hello@prem-ium.online" class="inline-flex items-center justify-center rounded-btn bg-accent px-6 py-3 font-medium text-white shadow-soft transition-transform hover:-translate-y-0.5">
        hello@prem-ium.online
      </a>
    </div>
  </section>

  <footer class="relative border-t border-border/60 px-6 py-10 text-center text-sm text-ink2" style="background:rgb(var(--bg-rgb) / 0.9)">
    <div class="mb-3 flex flex-wrap items-center justify-center gap-x-5 gap-y-2">
      <a href="/portfolio" class="hover:text-accent">All sites</a>
      <a href="https://portal.prem-ium.online" class="hover:text-accent">Client portal ↗</a>
      <a href="#contact" class="hover:text-accent">Contact</a>
    </div>
    <p class="mb-2">© {new Date().getFullYear()} prem-ium.online</p>
    <p class="opacity-70">{disclaimer}</p>
  </footer>

  <ThemeSwitcher client:load />
  <SmoothScroll client:load />
</Layout>
