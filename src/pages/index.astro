---
import Layout from '../layouts/Layout.astro';
import HeroCanvas from '../components/HeroCanvas.tsx';
import About from '../components/About.tsx';
import ParallaxGallery from '../components/ParallaxGallery.tsx';
import WorldGlobe from '../components/WorldGlobe.tsx';
import Services from '../components/Services.tsx';
import ThemeSwitcher from '../components/ThemeSwitcher.tsx';
import SmoothScroll from '../components/SmoothScroll.tsx';
import AnimatedHeadline from '../components/AnimatedHeadline.tsx';
import { hero, about, services, disclaimer } from '../data/site';
import { gallery } from '../data/gallery';
---
<Layout title="prem-ium.inc — Websites for local businesses" description={hero.sub}>
  <nav class="sticky top-0 z-40 flex items-center justify-between border-b border-white/10 bg-[#050608]/80 px-6 py-4 text-white backdrop-blur">
    <a href="#top" class="display text-lg font-semibold">prem-ium<span class="text-accent">.inc</span></a>
    <ul class="hidden gap-6 text-sm text-white/80 md:flex">
      <li><a href="#about" class="hover:text-accent">About</a></li>
      <li><a href="#work" class="hover:text-accent">Work</a></li>
      <li><a href="#charity" class="hover:text-accent">Charity</a></li>
      <li><a href="#services" class="hover:text-accent">Services</a></li>
      <li><a href="#contact" class="hover:text-accent">Contact</a></li>
    </ul>
    <a href="#contact" class="rounded-btn bg-accent px-4 py-2 text-sm font-medium text-white shadow-soft">Let's talk</a>
  </nav>

  <section id="top" class="relative overflow-hidden" style="background:rgba(5,6,8,0.55)">
    <div class="mx-auto grid min-h-[90vh] max-w-7xl items-center gap-6 px-6 py-16 md:grid-cols-2 md:gap-8">
      <div class="relative z-10 order-2 text-left md:order-1">
        <p class="eyebrow mb-4">{hero.eyebrow}</p>
        <AnimatedHeadline
          client:load
          as="h1"
          text={hero.headline}
          emphasize={hero.emphasize}
          className="text-5xl leading-[1.04] text-white md:text-6xl lg:text-7xl"
        />
        <p class="mt-6 max-w-md text-lg text-white/60">{hero.sub}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={hero.ctaHref} class="rounded-btn bg-accent px-6 py-3 font-medium text-white shadow-soft transition-transform hover:-translate-y-0.5">{hero.ctaLabel}</a>
          <a href={hero.ctaHref2} class="rounded-btn border border-white/20 px-6 py-3 font-medium text-white transition-colors hover:bg-white/5">{hero.ctaLabel2}</a>
        </div>
      </div>
      <div class="relative order-1 md:order-2">
        <HeroCanvas client:only="react" />
      </div>
    </div>
    <div class="pointer-events-none absolute bottom-6 left-1/2 -translate-x-1/2 text-xs uppercase tracking-[3px] text-white/40">Scroll ↓</div>
  </section>

  <About
    client:load
    eyebrow={about.eyebrow}
    headline={about.headline}
    emphasize={about.emphasize}
    paragraphs={about.paragraphs}
  />

  <section id="work" class="relative overflow-hidden px-6 py-20" style="background:rgba(5,6,8,0.5)">
    <div class="mx-auto max-w-6xl">
      <ParallaxGallery client:visible shots={gallery} />
    </div>
  </section>

  <section id="charity" class="relative flex flex-col items-center gap-8 overflow-hidden px-6 py-24 text-center" style="background:rgba(5,6,8,0.5)">
    <div class="max-w-3xl">
      <p class="eyebrow mb-4">Built free · Given away</p>
      <AnimatedHeadline client:visible as="h2" text="Every site we build, we give away free." emphasize={['free.']} className="mb-5 text-3xl leading-tight text-white md:text-5xl" />
      <p class="mx-auto mb-2 max-w-xl text-white/60">
        prem-ium.inc isn't just a portfolio — it's charity. Every website you see here was designed, built, and
        deployed at no cost, then handed to a local business that could never afford one. No fees, no catch.
      </p>
      <p class="mx-auto max-w-xl text-white/40 text-sm">
        Every screenshot on the globe is a real, free site. If one is yours,
        <a href="#contact" class="text-accent underline">it's yours to keep</a>.
      </p>
    </div>
    <div class="w-full max-w-5xl">
      <WorldGlobe client:visible />
    </div>
    <a href="#contact" class="inline-flex items-center justify-center rounded-btn bg-accent px-6 py-3 font-medium text-white shadow-soft transition-transform hover:-translate-y-0.5">
      Claim a free website →
    </a>
  </section>

  <section id="services" class="mx-auto max-w-6xl px-6 py-24">
    <AnimatedHeadline client:visible as="h2" text="What I do." className="mb-10 text-3xl md:text-4xl" />
    <Services client:visible items={services} />
  </section>

  <section id="contact" class="mx-auto max-w-2xl px-6 py-24 text-center">
    <AnimatedHeadline client:visible as="h2" text="Let's build something." emphasize={['something.']} className="mb-4 text-3xl md:text-4xl" />
    <p class="mb-8 text-ink2">Have a business that needs a real website — or think one of the free ones above is yours? Reach out.</p>
    <a href="mailto:hello@prem-ium.inc" class="inline-flex items-center justify-center rounded-btn bg-accent px-6 py-3 font-medium text-white shadow-soft transition-transform hover:-translate-y-0.5">
      hello@prem-ium.inc
    </a>
  </section>

  <footer class="border-t border-border/60 px-6 py-10 text-center text-sm text-ink2">
    <p class="mb-2">© {new Date().getFullYear()} prem-ium.inc</p>
    <p class="opacity-70">{disclaimer}</p>
  </footer>

  <ThemeSwitcher client:load />
  <SmoothScroll client:load />
</Layout>
