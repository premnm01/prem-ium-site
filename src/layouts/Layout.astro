---
import '../styles/global.css';
import AmbientBlobs from '../components/AmbientBlobs.tsx';
import FlyingBlob from '../components/FlyingBlob.tsx';
import Splash from '../components/Splash.tsx';
interface Props { title: string; description?: string; }
const { title, description = '' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#16130f" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Playfair+Display:wght@500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=Sora:wght@400;500;600;700&family=Syne:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Set data-theme before first paint to avoid a flash of the wrong theme.
      (function () {
        var THEMES = ['ember', 'moss', 'kinetic', 'sand', 'noir', 'rose', 'classic'];
        var params = new URLSearchParams(location.search);
        var fromUrl = params.get('theme');
        var theme = THEMES.includes(fromUrl)
          ? fromUrl
          : (localStorage.getItem('pi-theme') || 'moss');
        document.documentElement.dataset.theme = theme;
        // Always start at the top on reload/navigation — don't restore the
        // previous scroll position (which could land mid-page in About).
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';

        // Splash decision (runs on every page). Play the intro only on a
        // genuine reload OR the first page of the session — NOT on internal
        // navigation like portfolio → home, which is a full page load in an
        // MPA and would otherwise replay the intro. Read the "visited" flag
        // BEFORE setting it so the first page of the session still counts.
        try {
          var nav = performance.getEntriesByType('navigation')[0] || {};
          var navType = nav.type || 'navigate';
          var visited = sessionStorage.getItem('pi-visited');
          sessionStorage.setItem('pi-visited', '1');
          var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          var play = location.pathname === '/' && !reduce &&
                     (navType === 'reload' || !visited);
          window.__piPlaySplash = play;
          if (play) document.documentElement.classList.add('pi-splash');
        } catch (e) { window.__piPlaySplash = location.pathname === '/'; }
      })();
    </script>
  </head>
  <body>
    <Splash client:only="react" />
    <AmbientBlobs client:load />
    <FlyingBlob client:only="react" />
    <slot />
  </body>
</html>
